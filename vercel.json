{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/pages/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/frontend/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/frontend/pages/(.*)",
      "dest": "/frontend/pages/$1"
    },
    {
      "src": "/((?!api/|assets/|frontend/).*)",
      "dest": "/frontend/pages/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
