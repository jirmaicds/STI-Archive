# PHP Backend Routing Rules for x10hosting

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/
    
    # Allow direct access to JSON files in data directory
    RewriteRule ^data/(.*\.json)$ - [L]
    
    # Route all other requests to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Deny direct access to config
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>
